msgid "practice.packSummary.reasons.sentencesShortRhythm"
msgstr "A short sentence pack is safer in a shorter calm session than stretching it into a long scenario."

msgid "practice.packSummary.reasons.sentencesLongSurvival"
msgstr "Long phrases and larger text chunks open up better in a long, steady run."

msgid "practice.packSummary.reasons.sentencesNormalPractice"
msgstr "Connected text without extreme length fits best in regular mid-distance practice."

