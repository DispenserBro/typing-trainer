msgstr "Open {{mode}}"

msgid "practice.packPreflight.survival.title"
msgstr "This pack is too short for survival"

msgid "practice.packPreflight.survival.detail"
msgstr "A long distance will quickly run into repeats or heavy phrases. It is better to shorten the scenario or return to base material for a cleaner survival run."

msgid "practice.packPreflight.survival.actions.practice.label"
msgstr "Switch to practice"

msgid "practice.packPreflight.survival.actions.practice.description"
msgstr "Keep the current pack but move back to a calmer mid-distance scenario."

msgid "practice.packPreflight.survival.actions.base.label"
msgstr "Return to base material"

msgid "practice.packPreflight.survival.actions.base.description"
msgstr "Stay in survival, but remove the short pack and return to the standard adaptive material."

msgid "practice.packPreflight.practice.title"
msgstr "This pack is tight for normal practice"

msgid "practice.packPreflight.practice.detail"
msgstr "A mid-distance run will start repeating items too quickly. It is more useful to shorten the session or move the pack into a better-fitting mode in one click."

msgid "practice.packPreflight.practice.actions.shorten.label"
msgstr "Shorten the distance"

msgid "practice.packPreflight.practice.actions.shorten.description"
msgstr "Switch practice into rhythm mode and keep the current pack."

msgid "practice.packPreflight.practice.actions.base.label"
msgstr "Return to base material"

msgid "practice.packPreflight.practice.actions.base.description"
msgstr "Remove the custom pack and return to standard adaptive practice."

msgid "practice.packPreflight.sprint.title"
msgstr "Sprint becomes too heavy for sentences"

msgid "practice.packPreflight.sprint.detail"
msgstr "Long sentences under a timer add extra load and distort the clean pace signal. Either shorten the run or move to a better-fitting scenario."

msgid "practice.packPreflight.sprint.actions.shorten.label"
msgstr "Make the sprint shorter"

msgid "practice.packPreflight.sprint.actions.shorten.description"
msgstr "Keep the pack but quickly reduce the timer to the shortest distance."

msgid "practice.packPreflight.sprint.actions.rhythm.label"
msgstr "Switch to rhythm practice"

msgid "practice.packPreflight.sprint.actions.rhythm.description"
msgstr "For sentences, this pack works better in a short calm practice without a harsh timer."

msgid "practice.packPreflight.sprint.actions.base.label"
msgstr "Keep sprint, use base material"

msgid "practice.packPreflight.sprint.actions.base.description"
msgstr "Keep the timed mode and restore standard material instead of a heavy sentence pack."

msgid "practice.packPreflight.flawless.title"
msgstr "This mixed pack is too noisy for flawless survival"

msgid "practice.packPreflight.flawless.detail"
msgstr "A short mixed pack makes the flawless survival variant harsher than it needs to be. It is better to smooth out the material first or move back to normal practice."

msgid "practice.packPreflight.flawless.actions.practice.label"
msgstr "Switch to normal practice"

msgid "practice.packPreflight.flawless.actions.practice.description"
msgstr "Keep the current pack but move it into a softer scenario without instant failure."

msgid "practice.packPreflight.flawless.actions.base.label"
msgstr "Keep flawless survival, use base material"

msgid "practice.packPreflight.flawless.actions.base.description"
msgstr "Keep the flawless survival variant and return to standard material without the short mixed pool."

msgid "practice.packPreflight.info.title"
msgstr "This pack has a more natural scenario: {{mode}}"

msgid "practice.packPreflight.info.actions.switch.label"
msgstr "Switch to {{mode}}"

msgid "practice.packPreflight.info.actions.switch.description"
msgstr "Apply the recommended scenario and keep the current pack active."

