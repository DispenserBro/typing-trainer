{
  "name": "typing-trainer",
  "version": "2.0.0",
  "description": "Клавиатурный тренажёр с поддержкой русского и английского языков",
  "main": "dist/main/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "webpack --config webpack.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.typing-trainer.app",
    "productName": "Typing Trainer",
    "files": [
      "dist/**",
      "data/**"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "an-array-of-english-words": "^2.0.0",
    "css-loader": "^6.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "russian-words": "^1.0.1",
    "sass": "^1.72.0",
    "sass-loader": "^14.1.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
