{
  "name": "typing-trainer",
  "version": "2.1.0",
  "description": "Клавиатурный тренажёр с поддержкой русского и английского языков",
  "main": "dist/main/main.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "webpack --config webpack.config.js",
    "build": "npm run build:main && npm run build:renderer",
    "rebuild": "npm run clean && npm run build",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "build:win": "npm run build && electron-builder --win --publish never",
    "build:linux": "npm run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.typing-trainer.app",
    "productName": "Typing Trainer",
    "files": [
      "dist/**",
      "data/**"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "an-array-of-english-words": "^2.0.0",
    "css-loader": "^7.1.4",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "russian-words": "^1.0.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
