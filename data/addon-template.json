{
  "manifestVersion": 1,
  "id": "tech-english-pack",
  "name": "Технический английский",
  "version": "1.0.0",
  "description": "Расширенный словарь IT-терминов и дополнительные уроки по символам программирования для раскладки QWERTY. Включает тему оформления и два внутриигровых предмета.",
  "author": "example-author",
  "minAppVersion": "2.3.0",
  "type": "content",
  "resources": {
    "words": [
      {
        "lang": "en",
        "words": [
          "function", "variable", "constant", "callback", "promise",
          "async", "await", "interface", "abstract", "generic",
          "recursion", "iterator", "generator", "decorator", "middleware",
          "payload", "endpoint", "request", "response", "schema",
          "migration", "transaction", "repository", "dependency", "injection",
          "compiler", "interpreter", "runtime", "bytecode", "assembly",
          "pipeline", "namespace", "singleton", "prototype", "closure",
          "typescript", "javascript", "webpack", "eslint", "prettier"
        ]
      }
    ],
    "lessons": [
      {
        "layoutId": "qwerty",
        "lessons": [
          {
            "id": "tech-en-symbols-basic",
            "name": "Основные символы",
            "keys": [";", ":", "'", "\"", ",", ".", "/"],
            "section": "Символы",
            "description": "Пунктуация и базовые символы для кода. Правый мизинец и безымянный.",
            "type": "keys"
          },
          {
            "id": "tech-en-symbols-braces",
            "name": "Скобки и операторы",
            "keys": ["[", "]", "{", "}", "(", ")", "<", ">"],
            "section": "Символы",
            "description": "Скобки всех видов — самые частые символы в программировании.",
            "type": "keys"
          },
          {
            "id": "tech-en-symbols-special",
            "name": "Спецсимволы",
            "keys": ["!", "@", "#", "$", "%", "^", "&", "*", "-", "_", "=", "+"],
            "section": "Символы",
            "description": "Операторы и спецсимволы: шифт-ряд цифр плюс дефис и знак равенства.",
            "type": "keys"
          }
        ]
      }
    ],
    "items": {
      "items": [
        {
          "id": "tech-en-focus-lens",
          "name": "Линза отладчика",
          "shortName": "Отладка",
          "description": "Увеличивает допуск на точность — полезно при работе с незнакомыми символами.",
          "rarity": 1,
          "slotType": "trinket",
          "icon": "eye",
          "rewardKind": "simple",
          "accuracyRequirementReduction": 3,
          "effects": [
            { "kind": "accuracy", "value": 3, "unit": "percent", "description": "-3% к требуемой точности" }
          ]
        },
        {
          "id": "tech-en-pipeline-core",
          "name": "Ядро пайплайна",
          "shortName": "Пайплайн",
          "description": "Мощный артефакт на скорость и точность. Устойчив на обычных уровнях, теряет прочность при провалах.",
          "rarity": 3,
          "slotType": "trinket",
          "icon": "zap",
          "rewardKind": "durable",
          "speedRequirementReductionPercent": 8,
          "accuracyRequirementReduction": 4,
          "maxDurability": 5,
          "durabilityRules": { "normalPass": 0, "normalFail": 1, "bossPass": 1, "bossFail": 2 },
          "effects": [
            { "kind": "speed", "value": 8, "unit": "percent", "description": "-8% к требуемой скорости" },
            { "kind": "accuracy", "value": 4, "unit": "percent", "description": "-4% к требуемой точности" }
          ]
        }
      ]
    },
    "achievements": {
      "achievements": [
        {
          "id": "tech-en-symbol-sprint",
          "name": "Символьный спринт",
          "description": "Пройти урок «Скобки и операторы» без единой ошибки.",
          "category": "lessons"
        },
        {
          "id": "tech-en-full-vocab",
          "name": "Полный стек",
          "description": "Набрать 50 слов из технического словаря за одну тренировку.",
          "category": "practice",
          "conditions": [
             { "type": "practice.sessionCompleted" }
          ]
        }
      ]
    },
    "themes": {
      "themes": {
        "tech-dark": {
          "bg": "#0d1117",
          "surface": "#161b22",
          "surface2": "#21262d",
          "text": "#e6edf3",
          "subtext": "#8b949e",
          "accent": "#58a6ff",
          "green": "#3fb950",
          "red": "#f85149",
          "yellow": "#d29922"
        }
      }
    }
  }
}
